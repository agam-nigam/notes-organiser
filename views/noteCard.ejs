<!-- title -->
<div class="note">
    Title:
    <p class="details"><%= note.title %></p>
</div>

<!-- content -->
<div class="note">
    Content:
    <p class="details"><%= note.content %></p>
</div>

<!-- time -->
<% const isUpdated = note.updatedAt && note.updatedAt > note.createdAt;
   const date = isUpdated ? note.updatedAt : note.createdAt;
%>
<div class="note note-time">
  <span class="time-label"><%= isUpdated ? "Updated:" : "Created:" %></span>
  <span class="time-label">
    <%= new Date(date).toLocaleTimeString() %><br/>
    <%= new Date(date).toLocaleDateString() %>
  </span>
</div>

<!-- footer -->
<div class="note-footer">
    <form action="/notes/<%= note._id %>/edit" method="get">
        <button type="submit">Edit</button>
    </form>

    <form action="/notes/<%= note._id %>?_method=DELETE" method="post">
        <button type="submit"
            onclick="return confirm(`This action can't be reverted back. Are you sure to delete?`)">
            Delete
        </button>
    </form>

    <form action="/notes/<%= note._id %>?_method=PATCH" method="post">
        <button type="submit">
            <%= note.pinned ? "Unpin" : "Pin" %>
        </button>
    </form>
</div>